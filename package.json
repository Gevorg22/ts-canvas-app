{
  "name": "ts-canvas-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"vite\" \"tsx server/index.ts\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx server/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "canvaskit-wasm": "^0.41.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pixi.js-legacy": "^7.2.4",
    "skia-canvas": "^3.0.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "gh-pages": "^6.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
